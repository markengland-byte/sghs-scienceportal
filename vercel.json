{
  "version": 2,
  "name": "sghs-portal",
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "**/*.{html,css,json,png,jpg,jpeg,gif,svg,ico,webp}", "use": "@vercel/static" },
    { "src": "sol-prep/*.js", "use": "@vercel/static" },
    { "src": "shared/**/*.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
